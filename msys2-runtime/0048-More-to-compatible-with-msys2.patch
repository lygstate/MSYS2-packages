diff --git a/winsup/cygwin/local_includes/cygserver_setpwd.h b/winsup/cygwin/local_includes/cygserver_setpwd.h
index fc1576b05..b2975111c 100644
--- a/winsup/cygwin/local_includes/cygserver_setpwd.h
