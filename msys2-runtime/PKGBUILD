# Helper macros to help make tasks easier #
apply_patch_with_msg() {
  for _patch in "$@"
  do
    msg2 "Applying $_patch"
    patch -Nbp1 -i "${srcdir}/${_patch}"
  done
}

apply_git_am_with_msg() {
  for _patch in "$@"
  do
    msg2 "Applying $_patch"
    git apply "${srcdir}/${_patch}"
  done
}

del_file_exists() {
  for _fname in "$@"
  do
    if [ -f $_fname ]; then
      rm -rf $_fname
    fi
  done
}
# =========================================== #

# Function: exclude_list (list_to_filter, items_to_exclude)
exclude_list() {
  local -n arr=$1      # Reference to the main array
  local -n exclude=$2  # Reference to the exclusion array
  local -A ex_map      # Associative array for O(1) lookup
  local result=()

  # Build lookup map from the exclusion list
  for item in "${exclude[@]}"; do ex_map["$item"]=1; done

  # Filter the main array
  for item in "${arr[@]}"; do
      [[ -z "${ex_map[$item]}" ]] && result+=("$item")
  done

  # Output filtered list (or re-assign to original array if desired)
  echo "${result[@]}"
}

prepare() {
  cd "${srcdir}"/msys2-runtime
  if test true != "$(git config core.symlinks)"
  then
    git config core.symlinks true &&
    /usr/bin/git reset --hard
  fi
  del_file_exists winsup/cygwin/msys2_path_conv.cc \
    winsup/cygwin/msys2_path_conv.h

  if [[ "$MSYS_BOOTSTRAP_STAGE" == "stage_origin" ]]; then
      _patches=($(exclude_list _patches _patches_exclude_stage_origin))
  elif [[ "$MSYS_BOOTSTRAP_STAGE" == "stage_origin_hook" ]]; then
      _patches=($(exclude_list _patches _patches_exclude_stage_origin_hook))
  elif [[ "$_build_as_msys_2_dll" == "false" ]]; then
      _patches=($(exclude_list _patches _patches_exclude_for_cygwin_dll))
  else
    echo "Invalid MSYS_BOOTSTRAP_STAGE: '$MSYS_BOOTSTRAP_STAGE'" >&2
    exit -1
  fi

  for patch_filename in "${_patches[@]}"; do
    apply_git_am_with_msg ${patch_filename}
  done
}

build() {
  [[ -d "${srcdir}"/build-${CHOST} ]] && rm -rf "${srcdir}"/build-${CHOST}
  mkdir -p "${srcdir}"/build-${CHOST} && cd "${srcdir}"/build-${CHOST}

  # Gives more verbose compile output when debugging.
  local -a extra_config
  if check_option "debug" "y"; then
    export CCWRAP_VERBOSE=1
    OPTIM="-O0"
    extra_config+=(--enable-debugging)
  else
    OPTIM="-O2"
  fi

  CFLAGS="$OPTIM -pipe -ggdb"
  CXXFLAGS="$OPTIM -pipe -ggdb"

  # otherwise it asks git which appends "-dirty" because of our uncommited patches
  CFLAGS+=" -DCYGPORT_RELEASE_INFO=${pkgver}"

  (cd "${srcdir}/msys2-runtime/winsup" && ./autogen.sh)

  if [[ "$_build_as_msys_2_dll" == "true" ]]; then
    msys2_runtime_commit_id=$(cat "${srcdir}/msys2-runtime.commit")
  else
    msys2_runtime_commit_id=$(cat "${srcdir}/msys2-runtime-cygwin1.commit")
  fi

  "${srcdir}"/msys2-runtime/configure \
    --with-msys2-runtime-commit="$msys2_runtime_commit_id" \
    --prefix=/usr \
    --build=${CHOST} \
    --sysconfdir=/etc \
    "${extra_config[@]}"
  LC_ALL=C make

  if [[ "$MSYS_BOOTSTRAP_STAGE" == "stage0" ]]; then
    cp -af /usr/lib/libmsys-2.0.a /usr/lib/libmsys-2.0.a.origin
    cp -af /usr/lib/libcygwin.a /usr/lib/libcygwin.a.origin
    cp -af /usr/lib/libg.a /usr/lib/libg.a.origin
    cp -af /usr/lib/crt0.o /usr/lib/crt0.o.origin
    cp -f ./x86_64-pc-cygwin/winsup/cygwin/libcygwin.a /usr/lib/libmsys-2.0.a
    cp -f ./x86_64-pc-cygwin/winsup/cygwin/libcygwin.a /usr/lib/libcygwin.a
    cp -f ./x86_64-pc-cygwin/winsup/cygwin/libcygwin.a /usr/lib/libg.a
    cp -f ./x86_64-pc-cygwin/winsup/cygwin/crt0.o /usr/lib/crt0.o
    cp -f ./x86_64-pc-cygwin/winsup/cygwin/gcrt0.o /usr/lib/gcrt0.o
    find | grep \\.exe$ | xargs -I ARG rm -f ARG

    LC_ALL=C make
  fi

  LC_ALL=C make -j1 DESTDIR="${srcdir}"/dest install

  if [[ "$MSYS_BOOTSTRAP_STAGE" == "stage0" ]]; then
    cp -af /usr/lib/libmsys-2.0.a.origin /usr/lib/libmsys-2.0.a
    cp -af /usr/lib/libcygwin.a.origin /usr/lib/libcygwin.a
    cp -af /usr/lib/libg.a.origin /usr/lib/libg.a
    cp -af /usr/lib/crt0.o.origin /usr/lib/crt0.o
    rm /usr/lib/*.origin
  fi

  rm -rf "${srcdir}"/dest/etc

  if [[ "$_build_as_msys_2_dll" == "true" ]]; then
    # split debug info from msys-2.0.dll
    cd "${srcdir}"/dest
    objcopy --add-gnu-debuglink=/dev/null --only-keep-debug usr/bin/msys-2.0.dll usr/bin/msys-2.0.dbg
    objcopy -g --add-gnu-debuglink=usr/bin/msys-2.0.dbg usr/bin/msys-2.0.dll usr/bin/msys-2.0.dll.new
    mv -f usr/bin/msys-2.0.dll.new usr/bin/msys-2.0.dll
  else
    # split debug info from cygwin1.dll
    cd "${srcdir}"/dest
    objcopy --add-gnu-debuglink=/dev/null --only-keep-debug usr/bin/cygwin1.dll usr/bin/cygwin1.dbg
    objcopy -g --add-gnu-debuglink=usr/bin/cygwin1.dbg usr/bin/cygwin1.dll usr/bin/cygwin1.dll.new
    mv -f usr/bin/cygwin1.dll.new usr/bin/cygwin1.dll
  fi
}

package_msys2-runtime() {
  pkgdesc="Posix emulation engine for Windows"
  conflicts=('catgets' 'libcatgets' 'msys2-runtime-3.6')
  replaces=('catgets' 'libcatgets' 'msys2-runtime-3.6')

  mkdir -p "${pkgdir}"/usr
  cp -rf "${srcdir}"/dest/usr/bin "${pkgdir}"/usr/
  cp -rf "${srcdir}"/dest/usr/libexec "${pkgdir}"/usr/
  if [[ "$_build_as_msys_2_dll" == "true" ]]; then
    rm -f "${pkgdir}"/usr/bin/msys-2.0.dbg
  else
    rm -f "${pkgdir}"/usr/bin/cygwin1.dbg
  fi
  rm -f "${pkgdir}"/usr/bin/cyglsa-config
  rm -f "${pkgdir}"/usr/bin/cyglsa.dll
  rm -f "${pkgdir}"/usr/bin/cyglsa64.dll
  rm -f "${pkgdir}"/usr/bin/cygserver-config
  cp -rf "${srcdir}"/dest/usr/share "${pkgdir}"/usr/
}

package_msys2-runtime-devel() {
  pkgdesc="MSYS2 headers and libraries"
  depends=("msys2-runtime=${pkgver}")
  conflicts=('libcatgets-devel' 'msys2-runtime-3.6-devel')
  replaces=('libcatgets-devel' 'msys2-runtime-3.6-devel')
  # strip breaks the split debug info.  msys2/msys2-pacman#52
  options=('!strip')

  mkdir -p "${pkgdir}"/usr/bin
  if [[ "$_build_as_msys_2_dll" == "true" ]]; then
    cp -f "${srcdir}"/dest/usr/bin/msys-2.0.dbg "${pkgdir}"/usr/bin/
  else
    cp -f "${srcdir}"/dest/usr/bin/cygwin1.dbg "${pkgdir}"/usr/bin/
  fi
  cp -rLf "${srcdir}"/dest/usr/${CHOST}/include "${pkgdir}"/usr/
  rm -f "${pkgdir}"/usr/include/iconv.h
  rm -f "${pkgdir}"/usr/include/unctrl.h
  # provided by libtirpc
  rm -fr "${pkgdir}"/usr/include/rpc/

  cp -rLf "${srcdir}"/dest/usr/${CHOST}/lib "${pkgdir}"/usr/

  if [[ "$_build_as_msys_2_dll" == "true" ]]; then
    # compatibility with Cygwin toolchains
    cp "${srcdir}"/dest/usr/${CHOST}/lib/libmsys-2.0.a "${pkgdir}"/usr/lib/libcygwin.a
  else
    # compatibility with Msys2 toolchains for bootstrap
    cp "${srcdir}"/dest/usr/${CHOST}/lib/libcygwin.a "${pkgdir}"/usr/lib/libmsys-2.0.a
  fi
}
