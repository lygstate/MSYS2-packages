prepare() {
  cd ${srcdir}/expect${pkgver}
  patch -p1 -i ${srcdir}/0001-support-openpty.patch
  patch -p1 -i ${srcdir}/0002-fixes-random.patch
  patch -p1 -i ${srcdir}/0003-fixes-log_file.patch
  # patch -p1 -i ${srcdir}/0004-fixes-pkgpath.patch
  patch -p1 -i ${srcdir}/0005-fixes-covscan.patch
  patch -p1 -i ${srcdir}/0006-tclsh8-fixes.patch
  patch -p1 -i ${srcdir}/0007-unification-of-usage-and-man-page.patch
  patch -p1 -i ${srcdir}/0008-check-telnet.patch
  patch -p1 -i ${srcdir}/0009-fixes-exp_log-buf-overflow.patch
  patch -p1 -i ${srcdir}/0010-fixes-fd-leak-in-exp_command.c.patch
  patch -p1 -i ${srcdir}/0011-format-security-in-exp_clib.c.patch
  patch -p1 -i ${srcdir}/0012-man-page-update.patch
  patch -p1 -i ${srcdir}/0013-match-gt-numchars-segfault.patch
  patch -p1 -i ${srcdir}/0014-mkpasswd-for-dash.patch
  patch -p1 -i ${srcdir}/0015-mkpasswd.man-update.patch
  patch -p1 -i ${srcdir}/0016-passmass-use-su-full-path.patch
  patch -p1 -i ${srcdir}/0017-fixes-memleak-in-expect.c.patch
  patch -p1 -i ${srcdir}/0018-fixes-segfault-with-stubs.patch
  patch -p1 -i ${srcdir}/0019-fixes-with-c99.patch
  patch -p1 -i ${srcdir}/0020-fixes-configure-with-c99.patch
  patch -p1 -i ${srcdir}/0021-fixes-compile-with-c99-with-cygwin-gcc-15.2.patch

  autoreconf -vfi
}

build() {
  cd ${srcdir}/expect${pkgver}
  export MSYSTEM=CYGWIN
  ./configure --build=${CHOST} --prefix=/usr --mandir=/usr/share/man 
  make SHLIB_LD='$(CC) -shared -Wl,--out-implib,$@.a'
}

check() {

  cd ${srcdir}/expect${pkgver}
  make test
}

package() {
  cd ${srcdir}/expect${pkgver}
  make DESTDIR=${pkgdir} install

  mv ${pkgdir}/usr/lib/expect${pkgver}/libexpect${pkgver}.dll ${pkgdir}/usr/bin/libexpect${pkgver}.dll

  # mkpasswd is provided by cygwin, so this would conflict
  rm ${pkgdir}/usr/bin/mkpasswd
  rm ${pkgdir}/usr/share/man/man1/mkpasswd.1
  
  sed -i -e 's|\(\$dir\)|\1 .. .. bin|' ${pkgdir}/usr/lib/expect${pkgver}/pkgIndex.tcl

  install -D -m644 README ${pkgdir}/usr/share/licenses/${pkgname}/README
}
