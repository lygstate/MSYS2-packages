# Maintainer: Alexey Pavlov <Alexpux@gmail.com>

pkgname=time
pkgver=1.9
pkgrel=3
pkgdesc="Utility for monitoring a program's use of system resources"
url='https://www.gnu.org/directory/time.html'
msys2_repository_url='https://cgit.git.savannah.gnu.org/cgit/time.git'
msys2_references=(
  "anitya: 4971"
)
license=('GPL')
arch=('i686' 'x86_64')
makedepends=('autotools' 'gcc')
source=(https://ftp.gnu.org/pub/gnu/${pkgname}/${pkgname}-${pkgver}.tar.gz
        0001-fixes-error-assignment-to-sighandler-aka-void-void-f.patch)
sha256sums=('fbacf0c81e62429df3e33bda4cee38756604f18e01d977338e23306a3e3b521e'
            '94fd733e48fadbade0b15a9aa5d75b437a23419abdf0e14ee91afb310e0b765a')

prepare() {
  cd "${pkgname}-${pkgver}"

  patch -p1 -i "${srcdir}/0001-fixes-error-assignment-to-sighandler-aka-void-void-f.patch"

  autoreconf -fisv
}

build() {
  cd "${srcdir}/${pkgname}-${pkgver}"

  ./configure \
    --prefix=/usr \
    --infodir=/usr/share/info \
    --build=${CHOST}
  make
}

package() {
  cd "${srcdir}/${pkgname}-${pkgver}"

  make exec_prefix="${pkgdir}/usr" infodir="${pkgdir}/usr/share/info" install
}
